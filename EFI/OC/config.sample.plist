				<string>25.99.99</string>
				<key>MinKernel</key>
				<string>23.0.0</string>
			</dict>
			<dict>
				<key>BundlePath</key>
				<string>FakePCIID.kext</string>
				<key>Enabled</key>
				<true/>
				<key>Note</key>
				<string>Kept enabled in the verified setup.</string>
			</dict>
		</array>
	</dict>
	<key>NVRAM</key>
	<dict>
		<key>Add</key>
		<dict>
			<key>7C436110-AB2A-4BBB-A880-FE41995C9F82</key>
